// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // パスワードハッシュ用フィールドを追加
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  apiKeys  ApiKey[]
  requests Request[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique      // ハッシュ化されたフルキー
  keyPrefix   String                // 表示用プレフィックス (例: ag_7f8a9b2c)
  description String?               // APIキーの説明（オプショナル）
  userId      String
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests Request[]

  @@index([key])
  @@index([keyPrefix])
  @@index([userId])
}

model Request {
  id            String   @id @default(cuid())
  userId        String
  apiKeyId      String?
  provider      String   // 'openai' or 'anthropic'
  model         String
  endpoint      String
  method        String
  statusCode    Int
  responseTime  Int      // in milliseconds
  tokensUsed    Int?
  cost          Float?
  requestBody   String?
  responseBody  String?
  errorMessage  String?
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
  @@index([statusCode])
  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model UsageStats {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  provider    String
  model       String
  requestCount Int     @default(0)
  tokensUsed  Int     @default(0)
  cost        Float   @default(0)
  avgResponseTime Int @default(0)

  @@unique([userId, date, provider, model])
  @@index([userId, date])
}
